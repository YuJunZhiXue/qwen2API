    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.0",
        "guzzlehttp/guzzle": "^7.0",
        "firebase/php-jwt": "^6.0",
        "vlucas/phpdotenv": "^5.0"
