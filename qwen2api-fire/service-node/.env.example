# Node.js Service Environment Variables

# API Key para comunicação com backend PHP
NODE_API_KEY=secret-key-change-in-production

# Porta do serviço
PORT=3000

# Configurações do Browser
BROWSER_POOL_SIZE=2
MAX_INFLIGHT_PER_BROWSER=1
BROWSER_TIMEOUT_MS=300000

# Qwen Configuration
QWEN_BASE_URL=https://chat.qwen.ai
DEFAULT_MODEL=qwen3.6-plus

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/qwen-node.log

# Rate Limiting
REQUEST_RATE_LIMIT=10
REQUEST_RATE_WINDOW_MS=60000
